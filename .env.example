# NexusURL Configuration
# Copy this to .env and adjust values

# Database
DB_USER=nexususer
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=nexusurl

# Security
JWT_SECRET=CHANGE_THIS_32_CHARACTER_SECRET_KEY
JWT_REFRESH_SECRET=CHANGE_THIS_ANOTHER_32_CHAR_SECRET

# Application URLs
APP_URL=http://187.77.183.14:1590
API_URL=http://187.77.183.14:7658/api
CORS_ORIGIN=http://187.77.183.14:1590

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=notifications@xus.me
EMAIL_PASS=your_app_specific_password

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_2FA=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUBLIC_API=true

# Logging
LOG_LEVEL=info
