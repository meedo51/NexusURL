generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String          @id @default(uuid()) @db.Uuid
  username                String          @unique @db.VarChar(50)
  email                   String          @unique @db.VarChar(255)
  passwordHash            String          @map("password_hash") @db.VarChar(255)
  bio                     String          @default("") @db.Text
  avatarUrl               String?         @map("avatar_url") @db.Text
  isActive                Boolean         @default(true) @map("is_active")
  emailVerified           Boolean         @default(false) @map("email_verified")
  emailVerificationToken  String?         @map("email_verification_token") @db.VarChar(255)
  twoFactorEnabled        Boolean         @default(false) @map("two_factor_enabled")
  twoFactorSecret         String?         @map("two_factor_secret") @db.VarChar(255)
  twoFactorBackupCodes    String[]        @map("two_factor_backup_codes")
  notificationEnabled     Boolean         @default(true) @map("notification_enabled")
  shortCodeLength         Int             @default(6) @map("short_code_length")
  includeUppercase        Boolean         @default(true) @map("include_uppercase")
  includeLowercase        Boolean         @default(true) @map("include_lowercase")
  includeNumbers          Boolean         @default(true) @map("include_numbers")
  apiKey                  String?         @unique @map("api_key") @db.VarChar(64)
  lastLoginAt             DateTime?       @map("last_login_at") @db.Timestamp(6)
  lastLoginIp             String?         @map("last_login_ip") @db.Inet
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime        @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt               DateTime?       @map("deleted_at") @db.Timestamp(6)

  sessions  UserSession[]
  links     Link[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @db.VarChar(500)
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent") @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model Link {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  longUrl         String    @map("long_url") @db.Text
  shortCode       String    @unique @map("short_code") @db.VarChar(50)
  customAlias     String?   @map("custom_alias") @db.VarChar(50)
  isCustom        Boolean   @default(false) @map("is_custom")
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  expirationDate  DateTime? @map("expiration_date") @db.Timestamp(6)
  oneTimeAccess   Boolean   @default(false) @map("one_time_access")
  accessCount     Int       @default(0) @map("access_count")
  uniqueVisitors  Int       @default(0) @map("unique_visitors")
  qrScans         Int       @default(0) @map("qr_scans")
  qrLastScanned   DateTime? @map("qr_last_scanned") @db.Timestamp(6)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkLogs      LinkLog[]
  oneTimeTokens OneTimeToken[]
  qrScanLogs    QRScanLog[]

  @@index([userId], map: "idx_links_user_id")
  @@index([shortCode], map: "idx_links_short_code")
  @@index([expirationDate], map: "idx_links_expiration")
  @@map("links")
}

model QRScanLog {
  id         String   @id @default(uuid()) @db.Uuid
  linkId     String   @map("link_id") @db.Uuid
  ipAddress  String?  @map("ip_address") @db.Inet
  userAgent  String?  @map("user_agent") @db.Text
  referer    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId], map: "idx_qr_scan_logs_link_id")
  @@index([createdAt], map: "idx_qr_scan_logs_created_at")
  @@map("qr_scan_logs")
}

model LinkLog {
  id          String   @id @default(uuid()) @db.Uuid
  linkId      String   @map("link_id") @db.Uuid
  accessedAt  DateTime @default(now()) @map("accessed_at") @db.Timestamp(6)
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.Text
  referer     String?  @db.Text
  countryCode String?  @map("country_code") @db.VarChar(2)
  city        String?  @db.VarChar(100)
  deviceType  String?  @map("device_type") @db.VarChar(20)
  browserName String?  @map("browser_name") @db.VarChar(50)
  osName      String?  @map("os_name") @db.VarChar(50)

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId], map: "idx_link_logs_link_id")
  @@index([accessedAt], map: "idx_link_logs_accessed_at")
  @@map("link_logs")
}

model OneTimeToken {
  id        String   @id @default(uuid()) @db.Uuid
  linkId    String   @map("link_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)

  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@map("one_time_tokens")
}

model EmailQueue {
  id          String    @id @default(uuid()) @db.Uuid
  toEmail     String    @map("to_email") @db.VarChar(255)
  subject     String    @db.VarChar(255)
  htmlContent String    @map("html_content") @db.Text
  textContent String?   @map("text_content") @db.Text
  status      String    @default("pending") @db.VarChar(20)
  priority    Int       @default(1)
  retryCount  Int       @default(0) @map("retry_count")
  lastError   String?   @map("last_error") @db.Text
  scheduledFor DateTime @default(now()) @map("scheduled_for") @db.Timestamp(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  sentAt      DateTime? @map("sent_at") @db.Timestamp(6)

  @@index([status, priority, scheduledFor], map: "idx_email_queue_status_priority")
  @@map("email_queue")
}
